# PostgreSQL — Azure Flexible Server
DATABASE_NAME=housing_compliance_demo
DATABASE_USER=pgadmin
DATABASE_HOST=psql-<project>-<env>.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_PASSWORD=<your-postgresql-password>
DATABASE_SSL=require

# Azure OpenAI (via AI Services / Foundry)
AZURE_OPENAI_ENDPOINT=https://swedencentral.api.cognitive.microsoft.com/
AZURE_OPENAI_API_KEY=<from Key Vault secret: openai-api-key>
AZURE_AI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search
SEARCH_ENDPOINT=https://srch-<project>-<env>.search.windows.net
SEARCH_API_KEY=<from Key Vault secret: search-api-key>
